PORT=8787
NODE_ENV=development

# 域名规划。留空时本地仍使用相对路径，例如 http://localhost:8787。
# 入口域名只负责跳转到线路选择页；线路域名才承载真实主站。
# ROUTE_ENTRY_HOSTS 放固定入口（例如主品牌 51cmtv.com）；备用入口可在后台外观页维护。
# 上线示例：
# ROUTE_ENTRY_HOSTS=51cmtv.com
# ROUTE_SELECTOR_ORIGIN=https://nav.51cmtv.com
# ROUTE_LINE_ORIGINS=https://line1.51cmtv.com,https://line2.51cmtv.com,https://line3.51cmtv.com
# PUBLIC_SITE_ORIGINS=https://line1.51cmtv.com,https://line2.51cmtv.com,https://line3.51cmtv.com
# PUBLIC_ADMIN_ORIGIN=https://admin.yourdomain.com
# PUBLIC_API_BASE_URL=https://api.yourdomain.com
# PUBLIC_MEDIA_BASE_URL=https://media.yourdomain.com
# SESSION_COOKIE_DOMAIN=.yourdomain.com
PUBLIC_SITE_ORIGIN=
PUBLIC_SITE_ORIGINS=
SITE_HOSTS=
ROUTE_ENTRY_HOSTS=
ROUTE_SELECTOR_ORIGIN=
ROUTE_SELECTOR_HOST=
ROUTE_SELECTOR_TITLE=51视频
ROUTE_SELECTOR_SUBTITLE=看片娱乐两不误
ROUTE_LINE_ORIGINS=
PUBLIC_ADMIN_ORIGIN=
PUBLIC_API_BASE_URL=
PUBLIC_MEDIA_BASE_URL=
ADMIN_HOST=
API_HOST=
MEDIA_HOST=
SESSION_COOKIE_DOMAIN=
CORS_ALLOW_ALL=0
POSTWAVE_LOGIN_RATE_WINDOW_SECONDS=900
POSTWAVE_LOGIN_RATE_MAX=10

# VPS 上线时填写 PostgreSQL 连接串。
# 示例：
# DATABASE_URL=postgres://postwave_user:your_password@127.0.0.1:5432/postwave
DATABASE_URL=
POSTWAVE_BACKUP_DIR=./backups
PG_DUMP_PATH=pg_dump

# 本地没装 PostgreSQL 时可用 file 跑通帖子 API；正式部署使用 postgres。
POSTWAVE_STORAGE=file
# 本地需要示例帖子时可设为 1；生产环境默认关闭。
# POSTWAVE_ENABLE_DEMO_SEED=1

# 管理后台服务端登录配置；正式部署必须改成强密码和随机密钥。
# 生产环境 NODE_ENV=production 时，缺少这些值会拒绝启动。
# 生成 SESSION_SECRET 示例：
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# 生成 ADMIN_PASSWORD_HASH 示例：
# node -e "const bcrypt=require('bcryptjs'); bcrypt.hash('你的强密码',12).then(console.log)"
SESSION_SECRET=change-this-to-a-long-random-secret
ADMIN_USERNAME=alun
ADMIN_PASSWORD_HASH=$2b$12$replace-with-your-bcrypt-hash
ADMIN_NAME=alun

# 媒体文件存储。正式部署填写 bunny.net Storage + CDN；
# 未填写时，本地会保存到 data/uploads 并返回 /uploads/... URL，方便本地测试。
BUNNY_STORAGE_ZONE=
BUNNY_STORAGE_ACCESS_KEY=
BUNNY_STORAGE_HOST=storage.bunnycdn.com
BUNNY_CDN_BASE_URL=https://media.yourdomain.com
POSTWAVE_IMAGE_UPLOAD_LIMIT_MB=100
POSTWAVE_VIDEO_UPLOAD_LIMIT_MB=5120
POSTWAVE_VIDEO_CHUNK_MB=50
POSTWAVE_TRANSCODE_CONCURRENCY=1

# 视频转码。VPS 需要安装 ffmpeg；如果命令不在 PATH，可填写绝对路径。
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
