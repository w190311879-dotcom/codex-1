# Copy this file to .env.telegram-poster locally, or to /var/www/telegram-poster/.env on the VPS.
# Do not commit real tokens.

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=
BOT_API_TOKEN=
POST_SOURCE_API_URL=https://51cmtv.com/api/bot/random-posts
FIXED_CONTENT=
TIMEZONE=Asia/Shanghai
DAILY_POST_LIMIT=15
IMAGES_PER_POST=6
GLOBAL_DEDUP=true
DRY_RUN=false
DATABASE_PATH=data/telegram_poster.sqlite3
HTTP_TIMEOUT_SECONDS=30
MAX_ATTEMPTS=5
LOOP_SLEEP_SECONDS=30
LOG_LEVEL=INFO
